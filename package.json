{
  "name": "mergelearn",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "skills/",
    "examples/",
    "docs/*.md",
    "docs/assets/screenshots/*.png",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/libCli.ts",
    "smoke": "npm run build && node dist/libCli.js --help >/tmp/mergelearn-help.txt",
    "smoke:package": "node scripts/packaged-smoke.mjs",
    "pack:dry-run": "npm run build && npm pack --dry-run",
    "prepack": "npm run build"
  },
  "keywords": [
    "local-first",
    "code-learning",
    "git-history",
    "developer-tools"
  ],
  "author": "Odra Labs",
  "license": "PolyForm-Noncommercial-1.0.0",
  "description": "Local-first learning for agent-authored lessons. Source-available for noncommercial use; commercial use requires permission from Odra Labs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odralabshq/mergelearn-tutor.git"
  },
  "homepage": "https://github.com/odralabshq/mergelearn-tutor#readme",
  "bugs": {
    "url": "https://github.com/odralabshq/mergelearn-tutor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ts-fsrs": "5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "type": "module",
  "bin": {
    "mergelearn": "./dist/libCli.js"
  },
  "engines": {
    "node": ">=20"
  }
}
