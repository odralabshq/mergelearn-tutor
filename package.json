{
  "name": "mergelearn-tutor",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "docs/*.md",
    "docs/assets/screenshots/*.png",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/libCli.ts",
    "smoke": "npm run build && node dist/libCli.js --help >/tmp/mergelearn-help.txt",
    "smoke:package": "node scripts/packaged-smoke.mjs",
    "pack:dry-run": "npm run build && npm pack --dry-run",
    "prepack": "npm run build"
  },
  "keywords": [
    "local-first",
    "code-learning",
    "git-history",
    "developer-tools"
  ],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "description": "Local-first, model-free learning library and FSRS review shell for agent-authored card sets",
  "dependencies": {
    "commander": "^12.1.0",
    "ts-fsrs": "5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "type": "module",
  "bin": {
    "mergelearn": "./dist/libCli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
